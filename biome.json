{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/openapi.yaml",
      "!**/mcp-manifest.json",
      "!**/golden-transcript.json",
      "!**/*.gen.ts",
      "!**/*.css",
      "!**/migrations",
      "!**/dist",
      "!**/pacts",
      "!**/.pnpm-store",
      "!**/evomaster-generated",
      "!services/moderator-agent/contracts",
      "!services/moderator-agent/evals"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": {
        "noExplicitAny": "error",
        "noUndeclaredEnvVars": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": { "enabled": true }
  },
  "overrides": [
    {
      "includes": [
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/*.property.test.ts",
        "**/tests/**",
        "**/*.config.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": { "noExplicitAny": "off" }
        }
      }
    }
  ]
}
