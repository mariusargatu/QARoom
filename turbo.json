{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "openapi:generate": {
      "outputs": ["openapi.yaml", "src/**/openapi.yaml"]
    },
    "asyncapi:generate": {
      "outputs": ["asyncapi.yaml", "src/**/asyncapi.yaml"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["test-results/**", "coverage/**"]
    }
  }
}
