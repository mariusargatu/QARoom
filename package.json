{
  "name": "qaroom",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test --concurrency=50%",
    "test:scripts": "vitest run --config vitest.scripts.config.ts",
    "coverage": "tsx scripts/coverage.ts",
    "check": "tsx scripts/gauntlet.ts --only 1",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:scripts && pnpm test-results:generate && pnpm mbt:results && pnpm test-results:verify && pnpm openapi:verify && pnpm asyncapi:verify && pnpm mcp:verify && pnpm tour:verify && pnpm chaos:verify && pnpm census && pnpm matrix:verify",
    "typecheck": "turbo run typecheck",
    "lint": "biome check . && eslint .",
    "lint:fix": "biome check --write . && eslint . --fix",
    "format": "biome format --write .",
    "openapi:generate": "turbo run openapi:generate",
    "openapi:verify": "tsx scripts/openapi-verify.ts",
    "mcp:generate": "pnpm --filter @qaroom/qaroom-mcp mcp:generate",
    "mcp:verify": "tsx scripts/mcp-verify.ts",
    "moderator:contracts": "tsx scripts/gen-moderator-contracts.ts",
    "asyncapi:generate": "turbo run asyncapi:generate",
    "asyncapi:verify": "tsx scripts/asyncapi-verify.ts",
    "pact:verify": "tsx scripts/pact-verify.ts",
    "pact:results": "tsx scripts/pact-results.ts",
    "schemathesis:results": "tsx scripts/schemathesis-results.ts",
    "tracetest:results": "tsx scripts/tracetest-results.ts",
    "coverage:results": "tsx scripts/coverage-results.ts",
    "scenario:results": "tsx scripts/scenario-results.ts",
    "gauntlet": "tsx scripts/gauntlet.ts",
    "gauntlet:report": "tsx scripts/gauntlet-report.ts",
    "matrix": "tsx scripts/detection-matrix.ts",
    "matrix:render": "tsx scripts/render-detection-matrix.ts",
    "matrix:verify": "tsx scripts/detection-matrix.ts --verify && tsx scripts/render-detection-matrix.ts --check",
    "jobs:gc-dedup": "pnpm --filter @qaroom/content exec tsx src/jobs/gc-dedup.ts",
    "jobs:gc-dedup:donations": "pnpm --filter @qaroom/donations exec tsx src/jobs/gc-dedup.ts",
    "jobs:gc-dedup:flags": "pnpm --filter @qaroom/flags exec tsx src/jobs/gc-dedup.ts",
    "jobs:gc-dedup:webhooks": "pnpm --filter @qaroom/webhooks exec tsx src/jobs/gc-dedup.ts",
    "jobs:gc-dedup:identity": "pnpm --filter @qaroom/identity exec tsx src/jobs/gc-dedup.ts",
    "test-results:generate": "tsx scripts/aggregate-test-results.ts",
    "test-results:verify": "tsx scripts/test-results-verify.ts",
    "test-results:report": "tsx scripts/render-test-summary.ts",
    "dev": "bash scripts/bootstrap-k3d.sh && tilt up",
    "dev:down": "tilt down ; bash scripts/teardown-k3d.sh",
    "visual": "bash scripts/visual.sh",
    "visual:update": "bash scripts/visual.sh --update",
    "smoke": "bash scripts/smoke.sh",
    "sim:dry": "tsx scripts/concurrent-sim.ts --dry-run",
    "sim": "tsx scripts/concurrent-sim.ts",
    "check:tenant-spans": "tsx scripts/check-tenant-spans.ts",
    "chaos:install": "bash scripts/chaos.sh install",
    "chaos:install:litmus": "bash scripts/chaos.sh install:litmus",
    "chaos:smoke": "bash scripts/chaos.sh smoke",
    "chaos:uninstall": "bash scripts/chaos.sh uninstall",
    "chaos:run": "vitest run --config tests/chaos/vitest.config.ts",
    "chaos:results": "tsx scripts/chaos-results.ts",
    "journey:run": "vitest run --config tests/journey/vitest.config.ts",
    "journey:results": "tsx scripts/journey-results.ts",
    "replay:capture": "tsx scripts/qaroom-replay.ts capture",
    "replay:load": "tsx scripts/qaroom-replay.ts load",
    "replay:regression": "pnpm --filter @qaroom/content exec tsx tests/snapshot-replay.verify.ts",
    "k6:gen": "tsx scripts/k6-gen-thresholds.ts",
    "k6:results": "tsx scripts/k6-results.ts",
    "stryker:critical": "tsx scripts/stryker-critical.ts",
    "stryker:results": "tsx scripts/stryker-results.ts",
    "evomaster": "tsx scripts/evomaster-run.ts",
    "evomaster:results": "tsx scripts/evomaster-results.ts",
    "moderator:verify": "tsx scripts/moderator-verify.ts",
    "mbt:results": "tsx scripts/mbt-coverage-results.ts",
    "prove": "tsx scripts/prove.ts",
    "claims:render": "tsx scripts/render-claims.ts",
    "stats:render": "tsx scripts/render-stats.ts",
    "cost:render": "tsx scripts/render-cost.ts",
    "boundaries:render": "tsx scripts/render-boundaries.ts",
    "claims:verify": "tsx scripts/claims-verify.ts",
    "tour:verify": "tsx scripts/verify-tour-anchors.ts",
    "chaos:verify": "tsx scripts/chaos-verify.ts",
    "census": "tsx scripts/census.ts",
    "pr:classify": "tsx scripts/pr-classify-run.ts",
    "reviewer:review": "tsx scripts/reviewer-agent.ts",
    "moderator:results": "tsx scripts/moderator-results.ts",
    "deepeval:results": "tsx scripts/deepeval-results.ts",
    "deepteam:results": "tsx scripts/deepteam-results.ts",
    "pyrit:results": "tsx scripts/pyrit-results.ts",
    "golden:results": "tsx scripts/golden-results.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@qaroom/contracts": "workspace:*",
    "@qaroom/testing-utils": "workspace:*",
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "eslint-plugin-qaroom": "workspace:*",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "catalog:",
    "yaml": "^2.7.0",
    "zod": "^4.0.0",
    "mutation-testing-metrics": "3.7.3"
  }
}
