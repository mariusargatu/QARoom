{
  "name": "@qaroom/qaroom-mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest/build-manifest.ts",
    "./transport/http": "./src/transport/http.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
