    subgraph 46 ["webhooks-service"]
      style 46 fill:#ffffff,stroke:#0b4884,color:#0b4884

      47["<div style='font-weight: bold'>fan-out consumer</div><div style='font-size: 70%; margin-top: 0px'>[Component: TS]</div><div style='font-size: 80%; margin-top:10px'>Durable consumer<br />(webhooks-fanout) of all five<br />entity subjects<br />(post.created, vote.cast,<br />flag.state.changed,<br />donation.state.changed,<br />moderation.decision.recorded).<br />Inserts one delivery row per<br />active subscription; dedup<br />via processed_events + unique<br />(subscription, event).</div>"]
      style 47 fill:#438dd5,stroke:#2e6295,color:#ffffff
      48["<div style='font-weight: bold'>repository</div><div style='font-size: 70%; margin-top: 0px'>[Component: TS]</div><div style='font-size: 80%; margin-top:10px'>Transactional mutation of<br />subscriptions + deliveries;<br />advisory lock; validates<br />against the delivery state<br />machine.</div>"]
      style 48 fill:#438dd5,stroke:#2e6295,color:#ffffff
      49["<div style='font-weight: bold'>delivery worker</div><div style='font-size: 70%; margin-top: 0px'>[Component: TS]</div><div style='font-size: 80%; margin-top:10px'>Relay loop: claims due rows<br />(FOR UPDATE SKIP LOCKED),<br />drives the webhook-delivery<br />XState machine, emits<br />xstate.transition spans<br />(reverse-conformance). Never<br />sleeps; uses injected Clock.</div>"]
      style 49 fill:#438dd5,stroke:#2e6295,color:#ffffff
      50["<div style='font-weight: bold'>delivery machine</div><div style='font-size: 70%; margin-top: 0px'>[Component: TS / XState]</div><div style='font-size: 80%; margin-top:10px'>Hand-authored<br />webhook-delivery XState<br />machine<br />(Pending/Delivering/Delivered/Retrying/DeadLettered;<br />DeliveryFailed is an event,<br />not a state). The single<br />authority on legal<br />transitions; MBT-walked.</div>"]
      style 50 fill:#438dd5,stroke:#2e6295,color:#ffffff
      51["<div style='font-weight: bold'>sender</div><div style='font-size: 70%; margin-top: 0px'>[Component: TS]</div><div style='font-size: 80%; margin-top:10px'>Injected WebhookSender seam:<br />fetch + AbortController<br />timeout (prod); programmable<br />double (tests). Signs with<br />HMAC-SHA256, timestamp bound<br />into the signature (replay<br />defense).</div>"]
      style 51 fill:#438dd5,stroke:#2e6295,color:#ffffff
      52["<div style='font-weight: bold'>SSRF guard</div><div style='font-size: 70%; margin-top: 0px'>[Component: TS]</div><div style='font-size: 80%; margin-top:10px'>Subscription URL validation:<br />public HTTPS only; rejects<br />loopback / private /<br />link-local. Toggle surface<br />for deliberate-bug demos.</div>"]
      style 52 fill:#438dd5,stroke:#2e6295,color:#ffffff
      53["<div style='font-weight: bold'>retry schedule</div><div style='font-size: 70%; margin-top: 0px'>[Component: TS]</div><div style='font-size: 80%; margin-top:10px'>Pure-function deterministic<br />capped + jittered backoff<br />from injected Randomness.<br />'The hardest-to-test part<br />made the easiest' (ADR-0019).</div>"]
      style 53 fill:#438dd5,stroke:#2e6295,color:#ffffff
