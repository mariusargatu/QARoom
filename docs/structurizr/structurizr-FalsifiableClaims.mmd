graph LR
  linkStyle default fill:#ffffff

  subgraph diagram ["Testing: the nine falsifiable claims"]
    style diagram fill:#ffffff,stroke:#ffffff

    subgraph group1 ["Architectural boundaries"]
      style group1 fill:#ffffff,stroke:#cccccc,color:#cccccc,stroke-dasharray:5

      145("<div style='font-weight: bold'>Async (events over NATS)</div><div style='font-size: 70%; margin-top: 0px'>[boundary]</div><div style='font-size: 80%; margin-top:10px'>Breaks on: a lost,<br />duplicated, or reordered<br />event</div>")
      style 145 fill:#b45309,stroke:#7d3a06,color:#ffffff
      148("<div style='font-weight: bold'>Tenancy (communities as tenants)</div><div style='font-size: 70%; margin-top: 0px'>[boundary]</div><div style='font-size: 80%; margin-top:10px'>Breaks on: one tenant reading<br />another's data</div>")
      style 148 fill:#b45309,stroke:#7d3a06,color:#ffffff
      151("<div style='font-weight: bold'>Observability (span structure)</div><div style='font-size: 70%; margin-top: 0px'>[boundary]</div><div style='font-size: 80%; margin-top:10px'>Breaks on: a span without its<br />tenant, a trace that breaks</div>")
      style 151 fill:#b45309,stroke:#7d3a06,color:#ffffff
      152("<div style='font-weight: bold'>External dependency (the LLM moderator)</div><div style='font-size: 70%; margin-top: 0px'>[boundary]</div><div style='font-size: 80%; margin-top:10px'>Breaks on: a hallucinated or<br />overconfident decision</div>")
      style 152 fill:#b45309,stroke:#7d3a06,color:#ffffff
      154("<div style='font-weight: bold'>Delivery edge (outbound webhooks)</div><div style='font-size: 70%; margin-top: 0px'>[boundary]</div><div style='font-size: 80%; margin-top:10px'>Breaks on: a replayed,<br />dropped, or unsafe delivery</div>")
      style 154 fill:#b45309,stroke:#7d3a06,color:#ffffff
    end

    subgraph group2 ["Falsifiable claims (pnpm prove)"]
      style group2 fill:#ffffff,stroke:#cccccc,color:#cccccc,stroke-dasharray:5

      205("<div style='font-weight: bold'>webhook-signing</div><div style='font-size: 70%; margin-top: 0px'>[CHAOS_WEBHOOK_SIGN_BODY_ONLY]</div><div style='font-size: 80%; margin-top:10px'>A signature binds the<br />timestamp: a captured (body,<br />signature) cannot be<br />replayed.</div>")
      style 205 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      206("<div style='font-weight: bold'>webhook-at-least-once</div><div style='font-size: 70%; margin-top: 0px'>[CHAOS_WEBHOOK_DROP_ON_FAIL]</div><div style='font-size: 80%; margin-top:10px'>Every delivery reaches a<br />terminal state; a failed send<br />is retried, never dropped.</div>")
      style 206 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      207("<div style='font-weight: bold'>moderator-abstain</div><div style='font-size: 70%; margin-top: 0px'>[MODERATOR_DISABLE_ABSTAIN]</div><div style='font-size: 80%; margin-top:10px'>Escalates to a human on low<br />confidence instead of<br />guessing.</div>")
      style 207 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      208("<div style='font-weight: bold'>moderator-no-confident-approve-of-flag</div><div style='font-size: 70%; margin-top: 0px'>[MODERATOR_DISABLE_APPROVE_GUARD]</div><div style='font-size: 80%; margin-top:10px'>An approve that diverges from<br />majority-remove precedent<br />escalates instead.</div>")
      style 208 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      209("<div style='font-weight: bold'>input-guard-fences-untrusted-body</div><div style='font-size: 70%; margin-top: 0px'>[MODERATOR_DISABLE_INPUT_GUARD]</div><div style='font-size: 80%; margin-top:10px'>Fences attacker-controlled<br />bodies as DATA before the<br />model.</div>")
      style 209 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      210("<div style='font-weight: bold'>retrieved-context-fenced</div><div style='font-size: 70%; margin-top: 0px'>[MODERATOR_DISABLE_CORPUS_GUARD]</div><div style='font-size: 80%; margin-top:10px'>Fences poisoned precedents /<br />policy text as DATA.</div>")
      style 210 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      211("<div style='font-weight: bold'>tenant-isolation</div><div style='font-size: 70%; margin-top: 0px'>[CONTENT_BUG_TENANT_LEAK]</div><div style='font-size: 80%; margin-top:10px'>A feed contains exactly its<br />own posts under any<br />cross-community interleave.</div>")
      style 211 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      212("<div style='font-weight: bold'>tenant-span-everywhere</div><div style='font-size: 70%; margin-top: 0px'>[CHAOS_TENANT_SPAN_DROP]</div><div style='font-size: 80%; margin-top:10px'>Every emitted span carries<br />tenant.id; a dropped stamp is<br />caught by the live Jaeger<br />audit.</div>")
      style 212 fill:#7c3aed,stroke:#5628a5,color:#ffffff
      213("<div style='font-weight: bold'>outbox-isolates-broker-latency</div><div style='font-size: 70%; margin-top: 0px'>[CHAOS_SYNC_PUBLISH]</div><div style='font-size: 80%; margin-top:10px'>The outbox keeps<br />mutating-HTTP latency<br />independent of the broker.</div>")
      style 213 fill:#7c3aed,stroke:#5628a5,color:#ffffff
    end


