{
  "name": "@qaroom/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:stories": "vitest run -c vitest.storybook.config.ts",
    "test:stories:coverage": "vitest run -c vitest.storybook.config.ts --coverage",
    "test:component": "vitest run -c vitest.component.config.ts",
    "test:component:coverage": "vitest run -c vitest.component.config.ts --coverage",
    "test:component:results": "tsx scripts/component-results.ts",
    "coverage": "vitest run -c vitest.coverage.config.ts --coverage",
    "census": "tsx scripts/component-census.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "e2e": "playwright test -c playwright.config.ts",
    "e2e:results": "tsx scripts/e2e-results.ts",
    "size": "size-limit"
  },
  "dependencies": {
    "@qaroom/contracts": "workspace:*",
    "@qaroom/determinism": "workspace:*",
    "@xstate/react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "xstate": "^5.32.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@qaroom/testing-utils": "workspace:*",
    "@size-limit/file": "12.1.0",
    "@storybook/addon-a11y": "10.5.3",
    "@storybook/addon-vitest": "10.5.3",
    "@storybook/react-vite": "10.5.3",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "catalog:",
    "fast-check": "catalog:",
    "msw": "^2.15.0",
    "size-limit": "12.1.0",
    "storybook": "10.5.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "catalog:",
    "vitest-browser-react": "2.2.0"
  }
}
