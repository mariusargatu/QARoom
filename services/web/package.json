{
  "name": "@qaroom/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "ct": "playwright test -c playwright-ct.config.ts",
    "ct:coverage": "COVERAGE=true playwright test -c playwright-ct.config.ts",
    "e2e": "playwright test -c playwright.config.ts",
    "coverage:merge": "tsx scripts/merge-coverage.ts"
  },
  "dependencies": {
    "@qaroom/contracts": "workspace:*",
    "@xstate/react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xstate": "^5.19.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/experimental-ct-react": "1.60.0",
    "@playwright/test": "1.60.0",
    "@qaroom/testing-utils": "workspace:*",
    "@storybook/addon-a11y": "^9.0.0",
    "@storybook/addon-vitest": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "fast-check": "^4.0.0",
    "monocart-coverage-reports": "^2.12.0",
    "msw": "^2.7.0",
    "storybook": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-istanbul": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
