{
  "name": "@qaroom/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:stories": "vitest run -c vitest.storybook.config.ts",
    "test:stories:coverage": "vitest run -c vitest.storybook.config.ts --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "ct": "playwright test -c playwright-ct.config.ts",
    "ct:coverage": "COVERAGE=true playwright test -c playwright-ct.config.ts",
    "ct:results": "tsx scripts/ct-results.ts",
    "e2e": "playwright test -c playwright.config.ts",
    "e2e:results": "tsx scripts/e2e-results.ts",
    "coverage:merge": "tsx scripts/merge-coverage.ts"
  },
  "dependencies": {
    "@qaroom/contracts": "workspace:*",
    "@qaroom/determinism": "workspace:*",
    "@xstate/react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.17.0",
    "xstate": "^5.19.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@playwright/experimental-ct-react": "1.60.0",
    "@playwright/test": "1.60.0",
    "@qaroom/testing-utils": "workspace:*",
    "@storybook/addon-a11y": "10.4.2",
    "@storybook/addon-vitest": "10.4.2",
    "@storybook/react-vite": "10.4.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "4.1.8",
    "@vitest/browser-playwright": "4.1.8",
    "@vitest/coverage-v8": "4.1.8",
    "fast-check": "^4.8.0",
    "monocart-coverage-reports": "^2.12.0",
    "msw": "^2.14.0",
    "storybook": "10.4.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-plugin-istanbul": "^8.0.0",
    "vitest": "4.1.8"
  }
}
