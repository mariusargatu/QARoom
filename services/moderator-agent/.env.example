# Copy to `.env` (gitignored) and fill in. Only the REAL-LLM path needs a key — the Promptfoo evals
# and the `llm`-marked metamorphic test. The deterministic test suite (uv run pytest) needs no key.
#
#   cp .env.example .env   # then set OPENAI_API_KEY
#
OPENAI_API_KEY=

# Optional overrides (defaults shown):
# MODERATOR_MODEL=openai:gpt-5.5-2026-04-23
# MODERATOR_EMBEDDING_MODEL=openai:text-embedding-3-small
# MODERATOR_REASONING_EFFORT=low
# MODERATOR_ENABLE_MANUAL_REVIEW=true
# MODERATOR_EVAL_BUDGET_TOKENS=200000

# Langfuse LLM-trace UI (spike, off by default). Set all three to export the LangGraph trajectory,
# pgvector retrieval, and each LLM generation (prompt + completion) as rich spans. The local stack
# (`pnpm dev`) runs Langfuse in-cluster and wires these automatically; set them here only to point a
# locally-run moderator at it. Host = http://langfuse.localhost (local stack) or any Langfuse URL.
# LANGFUSE_HOST=http://langfuse.localhost
# LANGFUSE_PUBLIC_KEY=pk-lf-qaroom-dev
# LANGFUSE_SECRET_KEY=sk-lf-qaroom-dev
