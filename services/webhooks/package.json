{
  "name": "@qaroom/webhooks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts",
    "./operations": "./src/operations.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "dev": "tsx watch --import ./src/telemetry.ts src/server.ts",
    "openapi:generate": "tsx src/openapi-build.ts",
    "asyncapi:generate": "tsx src/asyncapi-build.ts",
    "stryker": "stryker run"
  },
  "dependencies": {
    "@qaroom/contracts": "workspace:*",
    "@qaroom/determinism": "workspace:*",
    "@qaroom/messaging": "workspace:*",
    "@qaroom/otel": "workspace:*",
    "@qaroom/service-kit": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "postgres": "^3.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@pact-foundation/pact": "^13.0.0",
    "@fast-check/vitest": "catalog:",
    "@qaroom/content": "workspace:*",
    "@qaroom/testing-utils": "workspace:*",
    "@testcontainers/postgresql": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "fast-check": "catalog:",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "catalog:",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1"
  }
}
