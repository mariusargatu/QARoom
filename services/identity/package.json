{
  "name": "@qaroom/identity",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "stryker": "stryker run",
    "dev": "tsx watch --import ./src/telemetry.ts src/server.ts",
    "openapi:generate": "tsx src/openapi-build.ts"
  },
  "dependencies": {
    "@qaroom/contracts": "workspace:*",
    "@qaroom/determinism": "workspace:*",
    "@qaroom/messaging": "workspace:*",
    "@qaroom/otel": "workspace:*",
    "@qaroom/service-kit": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.10.0",
    "jose": "^6.2.3",
    "postgres": "^3.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@pact-foundation/pact": "^17.0.1",
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@fast-check/vitest": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "@qaroom/content": "workspace:*",
    "@qaroom/donations": "workspace:*",
    "@qaroom/testing-utils": "workspace:*",
    "@testcontainers/postgresql": "^12.0.4",
    "drizzle-kit": "^0.31.10",
    "fast-check": "catalog:",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "catalog:"
  }
}
