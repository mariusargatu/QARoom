{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "governance_comment": "Critical-modules list is GOVERNED in ADR-0016 (docs/adr/0016-testing-your-tests.md) — adding a module is an ADR, removing requires a retrospective.",
  "packageManager": "pnpm",
  "testRunner": "vitest",
  "plugins": ["@stryker-mutator/vitest-runner"],
  "vitest": { "configFile": "vitest.stryker.config.ts" },
  "mutate": ["src/rate-limiter.ts", "src/breaker-guarded-call.ts"],
  "ignoreStatic": true,
  "inPlace": true,
  "tempDirName": ".stryker-tmp",
  "reporters": ["json", "clear-text"],
  "jsonReporter": { "fileName": "../../test-results/stryker-gateway.json" },
  "thresholds": { "high": 90, "low": 80, "break": 80 }
}
