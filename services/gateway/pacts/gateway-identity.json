{
  "consumer": {
    "name": "gateway"
  },
  "interactions": [
    {
      "description": "a request for the JWKS",
      "pending": false,
      "providerStates": [
        {
          "name": "a signing key exists",
          "params": {
            "kid": "key_01HZY0K7M3QF8VN2J5RX9TB4CH"
          }
        }
      ],
      "request": {
        "method": "GET",
        "path": "/jwks.json"
      },
      "response": {
        "body": {
          "content": {
            "keys": [
              {
                "alg": "ES256",
                "crv": "P-256",
                "kid": "key_01HZY0K7M3QF8VN2J5RX9TB4CH",
                "kty": "EC",
                "use": "sig",
                "x": "MKBCTNIcKUSDii11ySs3526iDZ8AiTo7Tu6KPAqv7D4",
                "y": "4Etl6SRW2YiLUrN5vfvVHuhp7x8PxltmWWlbbM4IFyM"
              }
            ]
          },
          "contentType": "application/json",
          "encoded": false
        },
        "headers": {
          "Content-Type": [
            "application/json"
          ]
        },
        "matchingRules": {
          "body": {
            "$": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.keys": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.keys[*].alg": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^ES256$"
                }
              ]
            },
            "$.keys[*].crv": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^P-256$"
                }
              ]
            },
            "$.keys[*].kid": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^key_[0-9A-HJKMNP-TV-Z]{26}$"
                }
              ]
            },
            "$.keys[*].kty": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^EC$"
                }
              ]
            },
            "$.keys[*].use": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^sig$"
                }
              ]
            },
            "$.keys[*].x": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Za-z0-9_-]+$"
                }
              ]
            },
            "$.keys[*].y": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^[A-Za-z0-9_-]+$"
                }
              ]
            }
          },
          "status": {}
        },
        "status": 200
      },
      "type": "Synchronous/HTTP"
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "13.2.0"
    },
    "pactRust": {
      "ffi": "0.4.22",
      "models": "1.2.3"
    },
    "pactSpecification": {
      "version": "4.0"
    }
  },
  "provider": {
    "name": "identity"
  }
}