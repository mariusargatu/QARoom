      "mutating": false,
      "title": "List a subscription’s deliveries (proxied)",
      "description": "Returns the delivery ledger for a subscription — the observable retry contract.",
      "input_schema": {
        "type": "object",
        "properties": {
          "communityId": {
            "type": "string",
            "pattern": "^comm_[0-9A-HJKMNP-TV-Z]{26}$"
