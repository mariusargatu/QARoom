    {
      "name": "gateway_listEvents",
      "service": "gateway",
      "operation_id": "listEvents",
      "method": "GET",
      "path": "/api/communities/{communityId}/events",
      "mutating": false,
      "title": "Poll community events (WebSocket fallback)",
      "description": "Returns the push envelopes for a community after the given seq cursor — the polling fallback for the WebSocket stream (Commitment 11). Every event delivered over WS is also returned here.",
      "input_schema": {
        "type": "object",
        "properties": {
          "communityId": {
            "type": "string",
            "pattern": "^comm_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "after": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "communityId"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "gateway_listFlags",
      "service": "gateway",
      "operation_id": "listFlags",
      "method": "GET",
      "path": "/api/communities/{communityId}/flags",
      "mutating": false,
      "title": "List all flags for a community (proxied)",
      "description": "Returns every flag resolved for the community, with a read envelope, via flags-service.",
      "input_schema": {
        "type": "object",
        "properties": {
          "communityId": {
            "type": "string",
            "pattern": "^comm_[0-9A-HJKMNP-TV-Z]{26}$"
          }
