    {
      "name": "gateway_getWebhook",
      "service": "gateway",
      "operation_id": "getWebhook",
      "method": "GET",
      "path": "/api/communities/{communityId}/webhook-subscriptions/{subscriptionId}",
      "mutating": false,
      "title": "Get a single webhook subscription (proxied)",
