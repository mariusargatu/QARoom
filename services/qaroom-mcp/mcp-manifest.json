      "path": "/api/communities/{communityId}/donations",
      "mutating": false,
      "title": "List a community’s donations (proxied)",
      "description": "Returns the most recent donations in a community, newest first, via donations-service.",
      "input_schema": {
        "type": "object",
        "properties": {
          "communityId": {
            "type": "string",
