{
  "protocol_version": "2025-11-25",
  "server": {
    "name": "qaroom-mcp",
    "version": "0.1.0"
  },
  "tools": [
    {
      "name": "content_getPost",
      "service": "content",
      "operation_id": "getPost",
      "method": "GET",
      "path": "/api/posts/{postId}",
      "mutating": false,
      "title": "Get a single post",
      "description": "Returns a post by id, including its current score.",
      "input_schema": {
        "type": "object",
        "properties": {
          "postId": {
            "type": "string",
            "pattern": "^post_[0-9A-HJKMNP-TV-Z]{26}$"
          }
        },
        "required": [
          "postId"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "content_listCommunityFeed",
      "service": "content",
      "operation_id": "listCommunityFeed",
      "method": "GET",
      "path": "/api/communities/{communityId}/feed",
      "mutating": false,
      "title": "List a community feed",
      "description": "Returns the most recent posts in a community, newest first, with a read consistency envelope.",
      "input_schema": {
        "type": "object",
        "properties": {
          "communityId": {
            "type": "string",
            "pattern": "^comm_[0-9A-HJKMNP-TV-Z]{26}$"
          }
        },
        "required": [
          "communityId"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "gateway_getDonation",
      "service": "gateway",
      "operation_id": "getDonation",
      "method": "GET",
      "path": "/api/communities/{communityId}/donations/{donationId}",
      "mutating": false,
      "title": "Get a single donation (proxied)",
      "description": "Returns a donation by id within a community, via donations-service.",
      "input_schema": {
        "type": "object",
        "properties": {
          "communityId": {
            "type": "string",
            "pattern": "^comm_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "donationId": {
            "type": "string",
            "pattern": "^dntn_[0-9A-HJKMNP-TV-Z]{26}$"
          }
        },
        "required": [
          "communityId",
          "donationId"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "gateway_getModerationDecision",
      "service": "gateway",
      "operation_id": "getModerationDecision",
      "method": "GET",
      "path": "/api/communities/{communityId}/moderation-decisions/{decisionId}",
      "mutating": false,
      "title": "Get a single moderation decision (proxied)",
      "description": "Returns one grounded moderation decision by id within a community.",
      "input_schema": {
        "type": "object",
        "properties": {
          "communityId": {
            "type": "string",
            "pattern": "^comm_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "decisionId": {
            "type": "string",
            "pattern": "^mdec_[0-9A-HJKMNP-TV-Z]{26}$"
          }
        },
        "required": [
          "communityId",
          "decisionId"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "gateway_getPost",
      "service": "gateway",
