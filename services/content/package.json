{
  "name": "@qaroom/content",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/app.ts",
    "./operations": "./src/contract/operations.ts",
    "./db/migrate": "./src/db/migrate.ts",
    "./db/client": "./src/db/client.ts",
    "./erasure": "./src/erasure.ts",
    "./config/faults": "./src/config/faults.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev": "tsx watch --import ./src/telemetry.ts src/server.ts",
    "openapi:generate": "tsx src/openapi-build.ts",
    "asyncapi:generate": "tsx src/asyncapi-build.ts"
  },
  "dependencies": {
    "@qaroom/contracts": "workspace:*",
    "@qaroom/determinism": "workspace:*",
    "@qaroom/messaging": "workspace:*",
    "@qaroom/otel": "workspace:*",
    "@qaroom/service-kit": "workspace:*",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "postgres": "^3.4.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.2.0",
    "@fast-check/vitest": "catalog:",
    "@pact-foundation/pact": "^13.0.0",
    "@qaroom/testing-utils": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "@testcontainers/postgresql": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "fast-check": "catalog:",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "catalog:"
  }
}
